{
  "UserPromptSubmit": [
    {
      "matcher": "(?i)(starting|building|launching|naming|picking a name for) (a |my |our |the )?(new )?(project|product|startup|app|saas|tool|brand|company)",
      "hooks": [
        {
          "type": "command",
          "command": "printf 'Hint: the domain-whois-mcp plugin can check name availability across TLDs. Offer to run /find-name <concept> or invoke the project-name-finder skill / domain-strategist agent.\\n'"
        }
      ]
    }
  ],
  "PreToolUse": [
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/detect-project-init.js\"",
          "timeout": 2000
        }
      ]
    }
  ]
}
