{
  "name": "domain-whois-mcp",
  "version": "1.0.0",
  "description": "MCP server for domain WHOIS and RDAP lookups with native protocol support, IANA TLD discovery, and concurrent bulk checking",
  "type": "module",
  "bin": {
    "domain-whois-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "skill.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "whois",
    "rdap",
    "domain",
    "dns",
    "iana",
    "model-context-protocol",
    "claude",
    "ai-tools",
    "domain-lookup",
    "tld"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^20.17.32",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
